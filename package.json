{
	"name": "dashbook",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"description": "Dash.fi brand & design system portal",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write \"src/**/*.{svelte,ts,css,md}\"",
		"format:check": "prettier --check \"src/**/*.{svelte,ts,css,md}\"",
		"lint": "eslint .",
		"test": "vitest run",
		"spec-audit": "node --import tsx scripts/spec-audit/cli.ts"
	},
	"dependencies": {
		"@dashfi/svelte": "^0.5.0",
		"@date-fns/utc": "^2.1.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^0.577.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@resvg/resvg-js": "^2.6.2",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"formsnap": "^2.0.1",
		"mode-watcher": "^1.1.0",
		"shiki": "^4.0.2",
		"svelte-radix": "^2.0.2",
		"svelte-sonner": "^1.1.0",
		"svelte-tel-input": "^3.6.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.11",
		"@types/node": "^25.6.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^16.3.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.23.1",
		"typescript": "^5.6.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^6.3.5",
		"vitest": "^4.1.10"
	}
}
