    "muted-foreground": { "$type": "color", "$value": { "light": "#6e7878", "dark": "#8b9695" } },
    "accent": { "$type": "color", "$value": { "light": "#eceae0", "dark": "#181e1d" } },
    "accent-foreground": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-white}" } },
    "destructive": { "$type": "color", "$value": { "light": "#ff4000", "dark": "#ff4000" } },
    "destructive-foreground": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#ffffff" } },
    "brand": { "$type": "color", "$value": { "light": "{base.dash-jade}", "dark": "{base.dash-jade-lifted}" } },
    "brand-foreground": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#ffffff" } },
    "cobalt": { "$type": "color", "$value": { "light": "{base.dash-cobalt}", "dark": "{base.dash-cobalt}" } },
    "cobalt-foreground": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#ffffff" } },
    "orange": { "$type": "color", "$value": { "light": "#ff4000", "dark": "#ff4000" } },
    "orange-foreground": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#ffffff" } },
    "border": { "$type": "color", "$value": { "light": "#e8e6dc", "dark": "#1f2a29" } },
    "input": { "$type": "color", "$value": { "light": "#b6c0bf", "dark": "#1f2a29" } },
    "ring": { "$type": "color", "$value": { "light": "{base.dash-jade}", "dark": "{base.dash-jade-lifted}" } }
  },
  "tailwind-scale": {
    "$description": "Tailwind @theme radii + font families (single mode).",
    "radius-none": { "$type": "dimension", "$value": "0" },
    "radius-sm": { "$type": "dimension", "$value": "4px" },
    "radius-md": { "$type": "dimension", "$value": "6px" },
    "radius-lg": { "$type": "dimension", "$value": "8px" },
    "radius-full": { "$type": "dimension", "$value": "9999px" },
    "font-sans": { "$type": "fontFamily", "$value": "'Bai Jamjuree', ui-sans-serif, system-ui, sans-serif" },
    "font-mono": { "$type": "fontFamily", "$value": "'PP Supply Mono', ui-monospace, SFMono-Regular, monospace" },
    "font-display": { "$type": "fontFamily", "$value": "'PP Supply Mono', ui-monospace, monospace" }
  },
  "typography": {
    "$description": "Figma text styles (Title case / Variant). PP Supply Mono renders as IBM Plex Mono in Figma (brand mono absent); Bai Jamjuree native. size px, lineHeight/letterSpacing %.",
    "Heading / Display": { "family": "IBM Plex Mono", "style": "ExtraLight", "size": 72, "lineHeight": 90, "letterSpacing": -1, "case": "UPPER" },
    "Heading / Page label": { "family": "IBM Plex Mono", "style": "Regular", "size": 12, "lineHeight": 140, "letterSpacing": 30, "case": "UPPER" },
    "Heading / Section header": { "family": "IBM Plex Mono", "style": "Medium", "size": 11, "lineHeight": 140, "letterSpacing": 15, "case": "UPPER" },
