    "Body / Body sm": { "family": "Bai Jamjuree", "style": "Regular", "size": 13, "lineHeight": 150, "letterSpacing": -1, "case": "ORIGINAL" },
    "Body / Caption": { "family": "Bai Jamjuree", "style": "Regular", "size": 12, "lineHeight": 140, "letterSpacing": -1, "case": "ORIGINAL" }
  }
