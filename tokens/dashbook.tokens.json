    "m-warn-soft": { "$type": "color", "$value": { "light": "rgba(184, 100, 0, 0.1)", "dark": "rgba(217, 154, 60, 0.16)" } },
    "m-warn-border": { "$type": "color", "$value": { "light": "rgba(184, 100, 0, 0.28)", "dark": "rgba(217, 154, 60, 0.36)" } },
    "m-negative": { "$type": "color", "$value": { "light": "{base.dash-ink}", "dark": "#ebede4" } },
    "m-negative-soft": { "$type": "color", "$value": { "light": "rgba(37, 38, 29, 0.08)", "dark": "rgba(235, 237, 228, 0.12)" } },
    "m-negative-border": { "$type": "color", "$value": { "light": "rgba(37, 38, 29, 0.24)", "dark": "rgba(235, 237, 228, 0.3)" } }
  },
  "scale": {
    "$description": "Non-color scalars in the token layer (single mode).",
    "radius": { "$type": "dimension", "$value": "0" },
    "shadow-sm": { "$type": "shadow", "$value": "0 1px 2px 0 rgba(18, 59, 57, 0.08)" },
    "shadow-md": { "$type": "shadow", "$value": "0 6px 20px -6px rgba(18, 59, 57, 0.14), 0 1px 2px rgba(18, 59, 57, 0.06)" },
    "easing-out": { "$type": "cubicBezier", "$value": "cubic-bezier(0.16, 1, 0.3, 1)" },
    "easing-in": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0, 1, 1)" },
    "easing-default": { "$type": "cubicBezier", "$value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "dur-instant": { "$type": "duration", "$value": "50ms" },
    "dur-fast": { "$type": "duration", "$value": "150ms" },
    "dur-normal": { "$type": "duration", "$value": "300ms" },
    "dur-slow": { "$type": "duration", "$value": "500ms" }
  },
  "tailwind": {
    "$description": "Tailwind @theme colour roles (--color-*). Light/Dark. Generated into src/lib/generated/theme.css (imported by app.css). NOTE: primary=ink and destructive=orange here — this surface is what @dashfi/svelte utilities render with; the product token layer (--primary #000, --destructive #000) intentionally differs and is a documented follow-up to reconcile.",
    "background": { "$type": "color", "$value": { "light": "#faf8f1", "dark": "#0f1413" } },
    "foreground": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-white}" } },
    "card": { "$type": "color", "$value": { "light": "#faf8f1", "dark": "#0f1413" } },
    "card-foreground": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-white}" } },
    "popover": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#141a19" } },
    "popover-foreground": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-white}" } },
    "primary": { "$type": "color", "$value": { "light": "{base.dash-ink}", "dark": "{base.dash-white}" } },
    "primary-foreground": { "$type": "color", "$value": { "light": "#ffffff", "dark": "#000000" } },
    "secondary": { "$type": "color", "$value": { "light": "#eceae0", "dark": "#181e1d" } },
    "secondary-foreground": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-white}" } },
