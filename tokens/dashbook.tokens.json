    "m-border-strong": { "$type": "color", "$value": { "light": "rgba(37, 38, 29, 0.2)", "dark": "rgba(234, 230, 219, 0.24)" } },
    "m-accent": { "$type": "color", "$value": { "light": "{base.dash-jade}", "dark": "{base.dash-jade-lifted}" } },
    "m-accent-deep": { "$type": "color", "$value": { "light": "{base.dash-jade-deep}", "dark": "{base.dash-jade}" } },
    "m-accent-soft": { "$type": "color", "$value": { "light": "rgba(43, 96, 92, 0.1)", "dark": "rgba(91, 184, 176, 0.16)" } },
