{
  "$description": "Dashbook design tokens — the single source of truth. Generates CSS custom properties (src/lib/generated/tokens.css), a typed map (tokens.ts), and Figma variables (tokens/figma.tokens.json). DTCG-format with an inline {light,dark} mode extension for mode-varying tokens. Refs use {base.<name>} and resolve to var(--dash-*) in CSS / VARIABLE_ALIAS in Figma. Edit here, then run `pnpm tokens`.",
  "base": {
    "$description": "Brand primitives — the single source of every brand hex. Single mode.",
    "dash-cobalt": { "$type": "color", "$value": "#354cef" },
    "dash-cobalt-deep": { "$type": "color", "$value": "#2a3ecc" },
    "dash-periwinkle": { "$type": "color", "$value": "#b6c1f2" },
    "dash-mist": { "$type": "color", "$value": "#e7e7f0" },
    "dash-cream": { "$type": "color", "$value": "#ebede4" },
    "dash-white": { "$type": "color", "$value": "#ffffff" },
    "dash-yellow": { "$type": "color", "$value": "#ebff00" },
    "dash-yellow-glow": { "$type": "color", "$value": "rgba(235, 255, 0, 0.5)" },
    "dash-jade": { "$type": "color", "$value": "#2b605c" },
    "dash-jade-deep": { "$type": "color", "$value": "#123b39" },
    "dash-jade-lifted": { "$type": "color", "$value": "#5bb8b0" },
    "dash-ink": { "$type": "color", "$value": "#25261d" },
    "dash-graphite": { "$type": "color", "$value": "#505148" },
    "dash-graphite-soft": { "$type": "color", "$value": "#80817a" }
  },
  "product": {
    "$description": "Product semantic roles. Light/Dark. Consumed as --<name> in CSS and Product semantic collection in Figma.",
